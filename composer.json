{
    "name": "heyfolksapp/wordpress-hfa-spxp",
    "description": "WordPress plugin that exposes a blog via the SPXP protocol",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6"
    },
    "autoload-dev": {
        "psr-4": {
            "HeyFolksApp\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
